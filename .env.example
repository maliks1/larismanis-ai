# Example environment variables (safe to commit; replace with placeholders)

# Supabase (client-accessible)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=pk.your_anon_key_here

# Supabase (server-only - DO NOT PUT REAL SECRETS HERE)
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# Google Generative AI (server-only)
GOOGLE_GENERATIVE_AI_API_KEY=REPLACE_WITH_GOOGLE_AI_KEY
GEMINI_MODEL=gemini-2.5-flash
